# Pooled URL (Neon "-pooler" host) — used by the running API. Must include pgbouncer=true.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DATABASE?sslmode=require&pgbouncer=true"
# Direct URL (non-pooler host) — used by prisma db push / seed / migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DATABASE?sslmode=require"
DEEPSEEK_API_KEY="your-deepseek-api-key"
PORT=5000
JWT_SECRET="change-me-to-a-long-random-secret"
APP_URL="http://localhost:8080"
VENDOR_QUOTATION_EXPIRY_DAYS=7

# Make.com webhook — receives JSON POST and sends email from your scenario
EMAIL_WEBHOOK_URL="https://hook.us2.make.com/your-webhook-id"
EMAIL_FROM="sales@ceylonautomobile.co.nz"
PO_VENDOR_EMAIL="vendor@nzparts-supply.co.nz"
