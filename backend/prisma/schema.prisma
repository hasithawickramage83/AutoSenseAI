generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  WORKSHOP
  SUPPLIER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  role         UserRole
  createdAt    DateTime      @default(now())
  quotations   Quotation[]
  invoices     Invoice[]
  activityLogs ActivityLog[]
}

model VehicleMake {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  createdAt DateTime        @default(now())
  models    VehicleModel[]
  vendors   VendorMake[]
}

model VehicleModel {
  id      Int                  @id @default(autoincrement())
  makeId  Int?
  name    String
  make    VehicleMake?         @relation(fields: [makeId], references: [id], onDelete: Cascade)
  parts   Part[]
  vendors VendorVehicleModel[]

  @@unique([makeId, name])
}

model Part {
  id             Int          @id @default(autoincrement())
  name           String
  description    String?
  activeStatus   Int          @default(1)
  vehicleModelId Int
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])
  stocks         Stock[]
}

model Stock {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float
  partId   Int   @unique
  part     Part  @relation(fields: [partId], references: [id])
}

model Quotation {
  id              String          @id
  workshopId      Int?
  workshop        User?           @relation(fields: [workshopId], references: [id])
  vehicle         String
  description     String
  inputText       String
  aiResult        Json
  parts           Json
  damages         Json
  recommendations Json
  severity        String          @default("Medium")
  labourCost      Float           @default(0)
  status          String          @default("Pending")
  source          String          @default("WORKSHOP")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  invoice         Invoice?
  purchaseOrders         PurchaseOrder[]
  damageReport           DamageReport?
  vendorQuotationRequests VendorQuotationRequest[]
}

model Invoice {
  id          String    @id
  quotationId String    @unique
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  workshopId  Int
  workshop    User      @relation(fields: [workshopId], references: [id])
  lineItems   Json
  labourCost  Float     @default(0)
  total       Float
  status      String    @default("Draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PurchaseOrder {
  id          String     @id
  quotationId String?
  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  partName    String
  quantity    Int
  price       Float      @default(0)
  vendorEmail String     @default("vendor@nzparts-supply.co.nz")
  urgency     String     @default("Standard")
  status      String     @default("Draft")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model DamageReport {
  id          Int       @id @default(autoincrement())
  quotationId String?   @unique
  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  inputText   String
  aiResult    Json
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  message   String
  type      String
  createdAt DateTime @default(now())
}

model Vendor {
  id                  Int                      @id @default(autoincrement())
  companyName         String
  contactPerson       String
  email               String                   @unique
  address             String?
  contactNumber       String?
  status              VendorStatus             @default(ACTIVE)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  quotationRequests   VendorQuotationRequest[]
  makes               VendorMake[]
  vehicleModels       VendorVehicleModel[]
}

model VendorMake {
  vendorId Int
  makeId   Int
  vendor   Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  make     VehicleMake @relation(fields: [makeId], references: [id], onDelete: Cascade)

  @@id([vendorId, makeId])
}

model VendorVehicleModel {
  vendorId       Int
  vehicleModelId Int
  vendor         Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)

  @@id([vendorId, vehicleModelId])
}

model VendorQuotationRequest {
  id            Int                              @id @default(autoincrement())
  quotationId   String
  quotation     Quotation                        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  vendorId      Int
  vendor        Vendor                           @relation(fields: [vendorId], references: [id])
  requestedById Int
  token         String                           @unique
  status        String                           @default("Pending")
  expiresAt     DateTime
  sentAt        DateTime?
  openedAt      DateTime?
  respondedAt   DateTime?
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt
  parts         VendorQuotationRequestPart[]
  response      VendorQuotationResponse?
  activities    VendorQuotationRequestActivity[]

  @@unique([quotationId, vendorId])
}

model VendorQuotationRequestPart {
  id        Int                    @id @default(autoincrement())
  requestId Int
  request   VendorQuotationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partName  String
  quantity  Int                    @default(1)
}

model VendorQuotationResponse {
  id                    Int                    @id @default(autoincrement())
  requestId             Int                    @unique
  request               VendorQuotationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  estimatedDeliveryTime String?
  remarks               String?
  lineItems             Json
  submittedAt           DateTime               @default(now())
}

model VendorQuotationRequestActivity {
  id        Int                    @id @default(autoincrement())
  requestId Int
  request   VendorQuotationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  message   String
  type      String
  createdAt DateTime               @default(now())
}
